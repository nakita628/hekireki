{
  "name": "hekireki-monorepo",
  "private": "true",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "deps": "mkdir -p /tmp/pnpm-store && pnpm config set store-dir /tmp/pnpm-store &&rm -rf node_modules && rm -rf pnpm-lock.yaml && rm -rf ~/.pnpm-store && pnpm store prune && pnpm install --no-prefer-frozen-lockfile",
    "build": "pnpm -F hekireki build",
    "check": "vp check --fix",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "test": "vp test",
    "coverage": "vp test --coverage",
    "release": "pnpm -F hekireki release"
  },
  "devDependencies": {
    "@prisma/client": "^7.4.2",
    "@vitest/coverage-v8": "^4.1.0",
    "drizzle-kit": "^0.31.9",
    "hekireki": "workspace:*",
    "prisma": "^7.5.0",
    "vite-plus": "^0.1.0",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.32.1"
}
