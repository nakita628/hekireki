{
  "name": "hekireki-monorepo",
  "private": "true",
  "license": "MIT",
  "scripts": {
    "deps": "rm -rf node_modules && rm -rf pnpm-lock.yaml && pnpm install",
    "build": "pnpm -F hekireki build",
    "check": "pnpm biome check --write ./",
    "typecheck": "pnpm -F hekireki typecheck",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "release": "pnpm -F hekireki release"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@vitest/coverage-v8": "^4.0.18",
    "hekireki": "workspace:*",
    "vitest": "^4.0.18"
  }
}
