generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

generator HekirekiSeaORM {
    provider = "hekireki-sea-orm"
    output   = "sea_orm"
}

model Agent {
    id       String  @id @default(uuid())
    codeName String
    active   Boolean @default(true)
    priority Int     @default(1)
}
