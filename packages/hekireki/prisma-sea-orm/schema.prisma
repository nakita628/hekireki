generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

generator HekirekiSeaORM {
    provider = "hekireki-sea-orm"
    output   = "sea_orm"
}

enum Role {
    ADMIN
    USER
    MODERATOR
}

model User {
    id    String  @id @default(cuid())
    name  String
    bio   String?
    role  Role    @default(USER)
    posts Post[]
}

model Post {
    id      String  @id @default(cuid())
    title   String
    content String?
    userId  String
    user    User    @relation(fields: [userId], references: [id])
}
