generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "sqlite"
}

generator HekirekiArkType {
    provider = "hekireki-arktype"
    output   = "arktype"
    type     = true
    comment  = true
    relation = true
}

model User {
    /// Primary key
    /// @a."string.uuid"
    id    String @id @default(uuid())
    /// Display name
    /// @a."string"
    name  String
    posts Post[]
}

model Post {
    /// Primary key
    /// @a."string.uuid"
    id String @id @default(uuid())
    /// Article title
    /// @a."string"
    title String
    /// Body content
    /// @a."string"
    content String
    /// Foreign key
    /// @a."string.uuid"
    userId  String
    user    User   @relation(fields: [userId], references: [id])
}
