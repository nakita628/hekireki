generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "sqlite"
}

generator HekirekiEffect {
    provider = "hekireki-effect"
    output   = "effect-test/test.ts"
}

model User {
    /// @e.Schema.UUID
    id    String @id @default(uuid())
    /// @e.Schema.String
    name  String
}
