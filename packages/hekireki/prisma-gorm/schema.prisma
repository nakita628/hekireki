generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

generator Hekireki-GORM {
    provider = "hekireki-gorm"
    output   = "gorm"
}

model User {
    id     Int    @id @default(autoincrement())
    name   String
    posts  Post[]
}

model Post {
    id     Int    @id @default(autoincrement())
    title  String
    userId Int
    user   User   @relation(fields: [userId], references: [id])
}
