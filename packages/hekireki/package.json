{
  "name": "hekireki",
  "version": "0.9.1",
  "description": "Hekireki is a tool that generates validation schemas for Zod, Valibot, ArkType, and Effect Schema, as well as ER diagrams and DBML, from Prisma schemas annotated with comments.",
  "keywords": [
    "ajv",
    "arktype",
    "dbml",
    "docs",
    "documentation",
    "ecto",
    "effect",
    "go",
    "gorm",
    "json-schema",
    "mermaid",
    "prisma",
    "rust",
    "sea-orm",
    "typebox",
    "valibot",
    "zod"
  ],
  "homepage": "https://github.com/nakita628/hekireki",
  "bugs": {
    "url": "https://github.com/nakita628/hekireki/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nakita628/hekireki.git"
  },
  "bin": {
    "hekireki": "dist/cli/index.js",
    "hekireki-ajv": "dist/bin/ajv.js",
    "hekireki-arktype": "dist/bin/arktype.js",
    "hekireki-dbml": "dist/bin/dbml.js",
    "hekireki-docs": "dist/bin/docs.js",
    "hekireki-drizzle": "dist/bin/drizzle.js",
    "hekireki-ecto": "dist/bin/ecto.js",
    "hekireki-effect": "dist/bin/effect.js",
    "hekireki-gorm": "dist/bin/gorm.js",
    "hekireki-mermaid-er": "dist/bin/mermaid-er.js",
    "hekireki-sea-orm": "dist/bin/sea-orm.js",
    "hekireki-sqlalchemy": "dist/bin/sqlalchemy.js",
    "hekireki-typebox": "dist/bin/typebox.js",
    "hekireki-valibot": "dist/bin/valibot.js",
    "hekireki-zod": "dist/bin/zod.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "generate": "prisma generate",
    "deps": "rm -rf node_modules && pnpm install",
    "build": "tsdown",
    "conformance": "pnpm build && bash conformance/check.sh"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@prisma/generator-helper": "^7.8.0",
    "@resvg/resvg-js": "^2.6.2",
    "@softwaretechnik/dbml-renderer": "^1.0.31",
    "hono": "^4.12.27",
    "oxfmt": "^0.57.0"
  },
  "devDependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/client": "^7.8.0",
    "@sinclair/typebox": "^0.34.49",
    "@types/node": "^26.1.0",
    "@typescript/native-preview": "7.0.0-dev.20260701.1",
    "ajv": "^8.20.0",
    "arktype": "^2.2.2",
    "better-auth": "^1.6.23",
    "cuid": "^3.0.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.4",
    "json-schema-to-ts": "^3.1.1",
    "prisma": "^7.8.0",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "valibot": "1.4.2",
    "zod": "^4.4.3"
  }
}
