// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "sqlite"
}

generator Hekireki-ER {
  provider = "hekireki-mermaid-er"
  output   = "./"
}

generator Hekireki-Zod {
  provider = "hekireki-zod"
  type     = true
  comment  = true
}

generator Hekireki-Valibot {
  provider = "hekireki-valibot"
  type     = true
  comment  = true
}

generator Hekireki-ArkType {
  provider = "hekireki-arktype"
  type     = true
  comment  = true
}

generator Hekireki-Effect {
  provider = "hekireki-effect"
  type     = true
  comment  = true
}

generator Hekireki-Ecto {
  provider = "hekireki-ecto"
  output = "schema"
  app = "DBSchema"
}

generator Hekireki-DBML {
  provider = "hekireki-dbml"
  output   = "dbml/schema.dbml"
}

generator Hekireki-Drizzle {
  provider = "hekireki-drizzle"
}

model User {
  /// Unique identifier for the user
  /// @z.uuid()
  /// @v.pipe(v.string(), v.uuid())
  /// @a."string.uuid"
  /// @e.Schema.UUID
  id               String         @id @default(uuid())
  /// User's display name
  /// @z.string()
  /// @v.string()
  /// @a."string"
  /// @e.Schema.String
  name             String
  /// Unique username for the user
  /// @z.string()
  /// @v.string()
  /// @a."string"
  /// @e.Schema.String
  username         String         @unique
  /// User's biography or profile description
  /// @z.string().optional().default("")
  /// @v.nullish(v.string())
  /// @a."string | null"
  /// @e.Schema.NullOr(Schema.String)
  bio              String?        @default("")
  /// User's unique email address
  /// @z.email()
  /// @v.pipe(v.string(), v.email())
  /// @a."string.email"
  /// @e.Schema.String
  email            String         @unique
  /// Timestamp of email verification
  /// @z.date().nullable()
  /// @v.nullish(v.pipe(v.string(), v.isoDate()))
  /// @a."string.date.iso | null"
  /// @e.Schema.NullOr(Schema.DateFromString)
  emailVerified    DateTime?
  /// URL of user's image
  /// @z.url().nullable()
  /// @v.nullish(v.pipe(v.string(), v.url()))
  /// @a."string.url | null"
  /// @e.Schema.NullOr(Schema.String)
  image            String?
  /// URL of user's cover image
  /// @z.url().nullable()
  /// @v.nullish(v.pipe(v.string(), v.url()))
  /// @a."string.url | null"
  /// @e.Schema.NullOr(Schema.String)
  coverImage       String?
  /// URL of user's profile image
  /// @z.url().nullable()
  /// @v.nullish(v.pipe(v.string(), v.url()))
  /// @a."string.url | null"
  /// @e.Schema.NullOr(Schema.String)
  profileImage     String?
  /// Hashed password for security
  /// @z.string()
  /// @v.nullish(v.string())
  /// @a."string | null"
  /// @e.Schema.NullOr(Schema.String)
  hashedPassword   String?
  /// Timestamp when the user was created
  /// @z.iso.datetime()
  /// @v.pipe(v.string(), v.isoTimestamp())
  /// @a."string.date.iso"
  /// @e.Schema.DateFromString
  createdAt        DateTime       @default(now())
  /// Timestamp when the user was last updated
  /// @z.iso.datetime()
  /// @v.pipe(v.string(), v.isoTimestamp())
  /// @a."string.date.iso"
  /// @e.Schema.DateFromString
  updatedAt        DateTime       @updatedAt
  /// Flag indicating if user has unread notifications
  /// @z.boolean().default(false)
  /// @v.nullish(v.boolean())
  /// @a."boolean | null"
  /// @e.Schema.NullOr(Schema.Boolean)
  hasNotification Boolean?       @default(false)
  /// Posts created by the user
  posts            Post[]
  /// Comments created by the user
  comments         Comment[]
  /// Notifications received by the user
  notifications    Notification[]
  /// Followers of the user
  followers        Follow[]       @relation("Follower")
  /// Users the user is following
  following        Follow[]       @relation("Following")
  /// Likes created by the user
  likes            Like[]
}

model Post {
  /// Unique identifier for the post
  /// @z.uuid()
  /// @v.pipe(v.string(), v.uuid())
  /// @a."string.uuid"
  /// @e.Schema.UUID
  id        String    @id @default(uuid())
  /// Content of the post
  /// @z.string().min(1).max(1000)
  /// @v.pipe(v.string(), v.minLength(1), v.maxLength(1000))
  /// @a."1 <= string <= 1000"
  /// @e.Schema.String.pipe(Schema.minLength(1), Schema.maxLength(1000))
  body      String
  /// Timestamp when the post was created
  /// @z.iso.datetime()
  /// @v.pipe(v.string(), v.isoTimestamp())
  /// @a."string.date.iso"
  /// @e.Schema.DateFromString
  createdAt DateTime  @default(now())
  /// Timestamp when the post was last updated
  /// @z.iso.datetime()
  /// @v.pipe(v.string(), v.isoTimestamp())
  /// @a."string.date.iso"
  /// @e.Schema.DateFromString
  updatedAt DateTime  @updatedAt
  /// ID of the user who created the post
  /// @z.uuid()
  /// @v.pipe(v.string(), v.uuid())
  /// @a."string.uuid"
  /// @e.Schema.UUID
  userId    String
  /// User who created the post
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Comments on the post
  comments  Comment[]
  /// Likes on the post
  likes     Like[]
}

model Follow {
  /// ID of the user who is following
  /// @z.uuid()
  /// @v.pipe(v.string(), v.uuid())
  /// @a."string.uuid"
  /// @e.Schema.UUID
  followerId  String
  /// ID of the user being followed
  /// @z.uuid()
  /// @v.pipe(v.string(), v.uuid())
  /// @a."string.uuid"
  /// @e.Schema.UUID
  followingId String
  /// Timestamp when the follow relationship was created
  /// @z.iso.datetime()
  /// @v.pipe(v.string(), v.isoTimestamp())
  /// @a."string.date.iso"
  /// @e.Schema.DateFromString
  createdAt   DateTime @default(now())
  /// User who created the follow relationship (the follower)
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  /// User being followed
  following   User     @relation("Follower", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

model Like {
  /// ID of the user who liked the post
  /// @z.uuid()
  /// @v.pipe(v.string(), v.uuid())
  /// @a."string.uuid"
  /// @e.Schema.UUID
  userId    String
  /// ID of the post that was liked
  /// @z.uuid()
  /// @v.pipe(v.string(), v.uuid())
  /// @a."string.uuid"
  /// @e.Schema.UUID
  postId    String
  /// Timestamp when the like was created
  /// @z.iso.datetime()
  /// @v.pipe(v.string(), v.isoTimestamp())
  /// @a."string.date.iso"
  /// @e.Schema.DateFromString
  createdAt DateTime @default(now())
  /// User who liked the post
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Post that was liked
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
}

model Comment {
  /// Unique identifier for the comment
  /// @z.uuid()
  /// @v.pipe(v.string(), v.uuid())
  /// @a."string.uuid"
  /// @e.Schema.UUID
  id        String   @id @default(uuid())
  /// Content of the comment
  /// @z.string()
  /// @v.string()
  /// @a."string"
  /// @e.Schema.String
  body      String
  /// Timestamp when the comment was created
  /// @z.iso.datetime()
  /// @v.pipe(v.string(), v.isoTimestamp())
  /// @a."string.date.iso"
  /// @e.Schema.DateFromString
  createdAt DateTime @default(now())
  /// Timestamp when the comment was last updated
  /// @z.iso.datetime()
  /// @v.pipe(v.string(), v.isoTimestamp())
  /// @a."string.date.iso"
  /// @e.Schema.DateFromString
  updatedAt DateTime @updatedAt
  /// ID of the user who created the comment
  /// @z.uuid()
  /// @v.pipe(v.string(), v.uuid())
  /// @a."string.uuid"
  /// @e.Schema.UUID
  userId    String
  /// ID of the post this comment belongs to
  /// @z.uuid()
  /// @v.pipe(v.string(), v.uuid())
  /// @a."string.uuid"
  /// @e.Schema.UUID
  postId    String
  /// User who created the comment
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Post that was commented on
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([postId])
}

model Notification {
  /// Unique identifier for the notification
  /// @z.uuid()
  /// @v.pipe(v.string(), v.uuid())
  /// @a."string.uuid"
  /// @e.Schema.UUID
  id        String   @id @default(uuid())
  /// Content of the notification message
  /// @z.string()
  /// @v.string()
  /// @a."string"
  /// @e.Schema.String
  body      String
  /// ID of the user who receives the notification
  /// @z.uuid()
  /// @v.pipe(v.string(), v.uuid())
  /// @a."string.uuid"
  /// @e.Schema.UUID
  userId    String
  /// Timestamp when the notification was created
  /// @z.iso.datetime()
  /// @v.pipe(v.string(), v.isoTimestamp())
  /// @a."string.date.iso"
  /// @e.Schema.DateFromString
  createdAt DateTime @default(now())
  /// User who receives the notification
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
